Host *
    UseKeychain yes
    AddKeysToAgent yes
    ServerAliveInterval 30
    Compression yes

Host docker.machine
    HostName docker.machine
    IdentityFile ~/.ssh/docker_machine_id_ed25519
    StrictHostKeyChecking=no
    UserKnownHostsFile /dev/null
    ControlMaster auto
    ControlPath ~/.ssh/control-%C
    ControlPersist yes
